{
  "version": "example_ruleset_v1",
  "model": {
    "wire_filter": {
      "min_length": 0.0
    }
  },
  "rules": [
    {
      "rule_id": "wire.floating_endpoints",
      "enabled": true,
      "severity": "warning",
      "params": {
        "tol": 0.001
      },
      "applies_to": [
        "single_line",
        "electrical_schematic",
        "general_supported_electrical"
      ]
    },
    {
      "rule_id": "device.missing_label",
      "enabled": true,
      "params": {
        "radius": 10.0
      },
      "applies_to": [
        "single_line",
        "electrical_schematic",
        "general_supported_electrical"
      ]
    },
    {
      "rule_id": "device.duplicate_label",
      "enabled": true,
      "params": {}
    },
    {
      "rule_id": "device.label_pattern_invalid",
      "enabled": true,
      "severity": "warning",
      "params": {},
      "applies_to": [
        "single_line",
        "electrical_schematic",
        "general_supported_electrical"
      ]
    },
    {
      "rule_id": "electrical.component_missing_terminals",
      "enabled": true,
      "params": {}
    },
    {
      "rule_id": "electrical.component_unconnected",
      "enabled": true,
      "severity": "warning",
      "params": {}
    },
    {
      "rule_id": "electrical.transformer_same_net",
      "enabled": true,
      "params": {}
    },
    {
      "rule_id": "electrical.switch_same_net",
      "enabled": true,
      "params": {}
    },
    {
      "rule_id": "electrical.switchgear_role_connection",
      "enabled": true,
      "severity": "warning",
      "params": {},
      "applies_to": [
        "single_line",
        "electrical_schematic"
      ]
    },
    {
      "rule_id": "electrical.switchgear_feed_chain",
      "enabled": true,
      "severity": "warning",
      "params": {},
      "applies_to": [
        "single_line",
        "electrical_schematic"
      ]
    },
    {
      "rule_id": "electrical.tie_switchgear_dual_side",
      "enabled": true,
      "severity": "warning",
      "params": {},
      "applies_to": [
        "single_line",
        "electrical_schematic"
      ]
    },
    {
      "rule_id": "electrical.incoming_transformer_busbar_direction",
      "enabled": true,
      "severity": "warning",
      "params": {
        "min_axis_separation": 2.0
      },
      "applies_to": [
        "single_line"
      ]
    },
    {
      "rule_id": "electrical.tie_busbar_segment_consistency",
      "enabled": true,
      "severity": "warning",
      "params": {},
      "applies_to": [
        "single_line",
        "electrical_schematic"
      ]
    },
    {
      "rule_id": "electrical.busbar_underconnected",
      "enabled": true,
      "severity": "warning",
      "params": {
        "min_connected_terminals": 2
      }
    },
    {
      "rule_id": "electrical.branch_box_insufficient_branches",
      "enabled": true,
      "params": {
        "min_branch_terminals": 2
      }
    },
    {
      "rule_id": "electrical.relation_unresolved",
      "enabled": false,
      "params": {}
    }
  ]
}
